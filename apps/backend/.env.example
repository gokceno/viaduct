# Google Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Server
PORT=3000
DATA_DIR=./data

# Cloudflare Access JWT validation (production)
# CF_TEAM_DOMAIN: your Cloudflare Zero Trust team domain
# CF_AUD: the Application Audience tag from Cloudflare One → Access → Applications
CF_TEAM_DOMAIN=https://<your-team>.cloudflareaccess.com
CF_AUD=<your-application-aud-tag>

# Fallback username for local dev (no CF tunnel). Leave empty in production.
DEFAULT_USER=local

# Quiet period before AI summarization fires (minutes)
QUIET_PERIOD_MINUTES=30

# Language for AI-generated summaries and tasks (BCP-47 locale tag, e.g. en-US, tr-TR)
SUMMARY_LOCALE=en-US
