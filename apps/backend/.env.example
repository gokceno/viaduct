# Google Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Server
PORT=3000
DATA_DIR=./data

# Public URL of TinyAuth — used by the frontend for the logout redirect.
# Leave empty for local dev (no TinyAuth).
TINYAUTH_URL=

# Fallback username when no Remote-User header is present (local dev only).
# Do not set this in production.
DEFAULT_USER=local

# Quiet period before AI summarization fires (minutes)
QUIET_PERIOD_MINUTES=30

# Language for AI-generated summaries and tasks (BCP-47 locale tag, e.g. en-US, tr-TR)
SUMMARY_LOCALE=en-US
