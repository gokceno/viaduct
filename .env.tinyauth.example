# TinyAuth — forward-auth middleware
# APPURL must be the public URL of TinyAuth's login UI.
# OrbStack automatically exposes the tinyauth service at tinyauth.viaduct.orb.local:3000.
# The auth cookie is scoped to .viaduct.orb.local so it's shared across subdomains.
# Generate a user hash: docker run -i -t --rm ghcr.io/steveiliop56/tinyauth:v5 user create --interactive
# Dollar signs in bcrypt hashes must be doubled ($$) here
TINYAUTH_UI_TITLE=Viaduct
TINYAUTH_APP_URL=https://backend.viaduct.orb.local
TINYAUTH_AUTH_USERS=
